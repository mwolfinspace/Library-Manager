{
  "name": "xedryk-data-manager-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Electron desktop wrapper for Xedryk's Data Manager.",
  "main": "release/electron/main.js",
  "scripts": {
    "desktop:dev": "electron .",
    "desktop:build": "electron-builder --win nsis portable",
    "desktop:build:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.xedryk.data-manager",
    "productName": "Xedryk Data Manager",
    "directories": {
      "output": "release/dist"
    },
    "files": [
      "release/electron/**/*",
      "Manager Tools/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
